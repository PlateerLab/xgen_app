{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "XGEN",
  "version": "0.1.0",
  "identifier": "com.plateer.plateerag",
  "build": {
    "beforeBuildCommand": "cd ../frontend && npm install && TAURI_ENV=true NEXT_PUBLIC_BACKEND_HOST=https://xgen.x2bee.com NEXT_PUBLIC_BACKEND_PORT= npm run build",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "XGEN",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
